<section id="comments" class="giscus-wrapper mt-8">
  <button
    type="button"
    class="rounded border border-border px-3 py-2 text-sm hover:text-accent"
    data-load-comments
  >
    Load comments
  </button>
  <div class="giscus"></div>
</section>

<script is:inline>
  (function () {
    var wrapper = document.querySelector(".giscus-wrapper");
    var container = document.querySelector(".giscus");
    var loadButton = document.querySelector("[data-load-comments]");

    if (!wrapper || !container || !loadButton) return;
    if (container.querySelector("iframe.giscus-frame")) return;

    var loaded = false;
    var idle = function (cb) {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(cb, { timeout: 2000 });
      } else {
        setTimeout(cb, 1);
      }
    };

    var loadComments = function () {
      if (loaded) return;
      loaded = true;
      loadButton.remove();
      container.innerHTML = "";

      var theme =
        document.documentElement.getAttribute("data-theme") === "dark"
          ? "dark"
          : "light";

      var s = document.createElement("script");
      s.src = "https://giscus.app/client.js";
      s.setAttribute("data-repo", "devkoriel/blog-koriel-kr");
      s.setAttribute("data-repo-id", "R_kgDORVH_1w");
      s.setAttribute("data-category", "General");
      s.setAttribute("data-category-id", "DIC_kwDORVH_184C247J");
      s.setAttribute("data-mapping", "pathname");
      s.setAttribute("data-strict", "0");
      s.setAttribute("data-reactions-enabled", "1");
      s.setAttribute("data-emit-metadata", "0");
      s.setAttribute("data-input-position", "top");
      s.setAttribute("data-theme", theme);
      s.setAttribute("data-lang", "en");
      s.crossOrigin = "anonymous";
      s.async = true;
      container.appendChild(s);
    };

    loadButton.addEventListener("click", loadComments, { once: true });

    if ("IntersectionObserver" in window) {
      var observer = new IntersectionObserver(
        function (entries) {
          if (entries[0] && entries[0].isIntersecting) {
            observer.disconnect();
            idle(loadComments);
          }
        },
        { rootMargin: "400px 0px" }
      );
      observer.observe(wrapper);
    }

    if (window.location.hash === "#comments") {
      idle(loadComments);
    }

    document.addEventListener(
      "keydown",
      function (event) {
        if (!loaded && event.key === "Tab") idle(loadComments);
      },
      { once: true }
    );
  })();

  // Theme sync observer — register once globally
  if (!window._giscusObs) {
    window._giscusObs = new MutationObserver(function () {
      var theme = document.documentElement.getAttribute("data-theme");
      var frame = document.querySelector("iframe.giscus-frame");
      if (frame) {
        frame.contentWindow.postMessage(
          { giscus: { setConfig: { theme: theme === "dark" ? "dark" : "light" } } },
          "https://giscus.app"
        );
      }
    });
    window._giscusObs.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }
</script>
